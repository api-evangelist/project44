{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Position",
  "title": "Position",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "latitude": {
      "type": "number",
      "format": "double"
    },
    "longitude": {
      "type": "number",
      "format": "double"
    },
    "heading": {
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "speed": {
      "type": "number",
      "format": "double",
      "nullable": true
    },
    "speedUnit": {
      "type": "string",
      "enum": [
        "MPH",
        "KPH"
      ]
    }
  }
}